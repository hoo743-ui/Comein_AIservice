# Comein Frontend — 환경 변수 예시 (.env.local 로 복사해 사용)

# 카카오 지도(무료). https://developers.kakao.com → 애플리케이션 → JavaScript 키
# 설정하면 Campus가 실제 카카오 지도를 사용, 비워두면 스키매틱 맵으로 폴백(무료).
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Google 실연동(무료, 브라우저 OAuth). https://console.cloud.google.com
#  1) Calendar API + People API 사용 설정
#  2) OAuth 동의 화면(외부, 테스트 사용자에 본인 추가)
#  3) OAuth 클라이언트 ID(웹) — 승인된 JS 원본에 http://localhost:3000
# 설정하면 Contacts에서 실제 Google 캘린더·연락처를 가져옴(없으면 데모).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
